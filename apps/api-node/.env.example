# Environment variables for api-node (OrbitShield)
# Copy this to .env and fill in values

PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/orbitshield

# S3 (for file storage)
AWS_REGION=us-east-1
AWS_S3_BUCKET=orbitshield-data

# JWT Auth
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=1h

# CelesTrak API (no auth needed)
CELESTRAK_BASE_URL=https://celestrak.org

# Space-Track API (requires free account at space-track.org)
SPACE_TRACK_USERNAME=
SPACE_TRACK_PASSWORD=

# NOAA Space Weather Prediction Center (no auth needed)
NOAA_SWPC_BASE_URL=https://services.swpc.noaa.gov

# Stripe (test mode keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_COVERAGE_PRICE_ID=price_...

# Data ingestion intervals (cron expressions)
TLE_REFRESH_CRON=0 */4 * * *
WEATHER_REFRESH_CRON=*/30 * * * *
RISK_SNAPSHOT_CRON=0 * * * *
